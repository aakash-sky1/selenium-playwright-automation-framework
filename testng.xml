<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="Automation Suite" parallel="classes" thread-count="3" verbose="1">

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.ui.LoginTest"/>
        </classes>
    </test>

    <test name="API Tests">
        <classes>
            <class name="com.automation.tests.api.UserApiTest"/>
        </classes>
    </test>

    <test name="Regression Suite">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.automation.tests.ui.LoginTest"/>
        </classes>
    </test>

</suite>
